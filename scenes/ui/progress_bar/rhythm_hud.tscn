[sub_resource type="Shader" id="Shader_dash_cooldown"]
code = "shader_type canvas_item;

uniform float progress : hint_range(0.0, 1.0) = 1.0;
uniform vec4 track_color : source_color = vec4(0.16, 0.17, 0.19, 1.0);
uniform vec4 fill_color : source_color = vec4(0.02, 0.78, 1.0, 1.0);
uniform float inner_radius : hint_range(0.0, 1.0) = 0.62;
uniform float outer_radius : hint_range(0.0, 1.0) = 0.9;
uniform float edge_softness : hint_range(0.001, 0.1) = 0.018;

void fragment() {
	vec2 p = UV * 2.0 - 1.0;
	float radius = length(p);
	float outer = 1.0 - smoothstep(outer_radius, outer_radius + edge_softness, radius);
	float inner = smoothstep(inner_radius - edge_softness, inner_radius, radius);
	float ring = outer * inner;

	float angle = atan(p.y, p.x) + 1.57079632679;
	if (angle < 0.0) {
		angle += 6.28318530718;
	}

	float filled = step(angle / 6.28318530718, progress);
	vec4 color = mix(track_color, fill_color, filled);
	COLOR = vec4(color.rgb, color.a * ring);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_dash_cooldown"]
shader = SubResource("Shader_dash_cooldown")
shader_parameter/progress = 1.0
shader_parameter/track_color = Color(0.16, 0.17, 0.19, 1)
shader_parameter/fill_color = Color(0, 0.5882353, 0.77254903, 1)
shader_parameter/inner_radius = 0.62
shader_parameter/outer_radius = 0.9
shader_parameter/edge_softness = 0.018

